---
import { Image } from "astro:assets";

// Definimos qué datos puede recibir este componente
interface Props {
    titulo: string;
    subtitulo: string;
    video?: string;         // Opcional (por eso el signo ?)
    imagen_fondo?: string;  // Opcional
}

const { titulo, subtitulo, video, imagen_fondo } = Astro.props;

// Lógica de imágenes integrada para que el componente sea 100% independiente
const localImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/imagenes/*.{jpeg,jpg,png,gif,webp}",
    { eager: true }
);

const getImagePath = (jsonPath: string | undefined) => {
    if (!jsonPath) return null;
    const fullPath = `/src/assets${jsonPath}`;
    if (!localImages[fullPath])
        throw new Error(`La imagen "${fullPath}" no existe en src/assets.`);
    return localImages[fullPath].default;
};
---

<section class="relative w-full h-screen min-h-[600px] flex items-center justify-center text-center overflow-hidden">
    
    {video ? (
        <video
            autoplay
            loop
            muted
            playsinline
            class="absolute inset-0 w-full h-full object-cover z-0"
        >
            <source src={video} type="video/webm" />
            <source src={video.replace(".webm", ".mp4")} type="video/mp4" />
        </video>
    ) : imagen_fondo ? (
        <Image
            src={getImagePath(imagen_fondo)!}
            alt={`Fondo de ${titulo}`}
            width={1280}
            class="absolute inset-0 w-full h-full object-cover z-0"
        />
    ) : null}

    <div class="absolute inset-0 bg-kiarita-black/60 z-10"></div>

    <div class="relative z-20 px-6 max-w-4xl mx-auto mt-16 md:mt-0">
        <h1 class="font-commissioner font-extrabold text-5xl md:text-6xl text-kiarita-white mb-6 uppercase leading-tight drop-shadow-lg">
            {titulo}
        </h1>

        <p class="font-inter text-lg md:text-lg text-kiarita-gray-lighter drop-shadow-md">
            {subtitulo}
        </p>
    </div>
</section>