---
interface Props {
    title: string;
    descripcion?: string;
    colorTitulo?: string; // Color de titulo
    colorTexto?: string;   // Color de descripcion
    posicionTitulo?: string; // Posición de titulo
    tamañoTitulo?: string; // Tamaño de titulo
    parrafos?: string[];
}

const { 
    title, 
    tamañoTitulo = "text-3xl lg:text-4xl",
    descripcion = "", 
    colorTitulo = "text-kiarita-green", 
    colorTexto = "text-kiarita-gray-dark",
    posicionTitulo = "text-left",
    parrafos
} = Astro.props;
---

<div class="flex flex-col w-full">
    <h2
        class={`font-commissioner font-extrabold ${tamañoTitulo} ${colorTitulo} mb-6 leading-tight w-full ${posicionTitulo}`}
    >
        {title}
    </h2>
    {
        descripcion && (
            <p
                class={`mb-10 ${colorTexto} leading-relaxed text-base font-normal`}
            >
                {descripcion}
            </p>
        )
    }
    {
        parrafos && (
            <div class="flex flex-col gap-4 mb-10">
                {
                    parrafos.map((parrafo: string) => (
                        <p class={`font-inter text-kiarita-gray-dark leading-relaxed text-base`}>
                            {parrafo}
                        </p>
                    ))
                }
            </div>
        )
    }
</div>