---
interface Props {
    espacio?: string;
    height?: string;
    extrastyle?: string;
}

const { espacio, height, extrastyle } = Astro.props;
let estilo = "";
if (espacio === "derecha") {
    estilo = "pr-6 lg:pr-20";
} else if (espacio === "izquierda") {
    estilo = "pl-6 lg:pl-20";
}
---

<div class={`${height} ${estilo} ${extrastyle}`}>
    <slot />
</div>
