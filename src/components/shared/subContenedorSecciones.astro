---
interface Props {
    tipo?: string;
    height?: string;
    extrastyle?: string;
}

const { tipo, height, extrastyle } = Astro.props;
let estilo = "px-6 lg:px-20";
if (tipo === "derecha") {
    estilo = "pr-6 lg:pr-20";
} else if (tipo === "izquierda") {
    estilo = "pl-6 lg:pl-20";
}  

---
<div class={`py-24 xl:py-32 ${estilo} ${height} ${extrastyle}`}>
    <slot />
</div>