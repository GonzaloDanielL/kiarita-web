---
import { Image } from "astro:assets";

interface Evento {
    subtitulo: string;
    texto: string;
}

interface Props {
    periodo: string;
    eventos: Evento[];
    imagen: string;
    pie_imagen: string;
    isReverse?: boolean; // Para intercalar el diseño
}

const { periodo, eventos, imagen, pie_imagen, isReverse = false } = Astro.props;

// Lógica de imágenes (misma que ya usabas)
const localImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/imagenes/*.{jpeg,jpg,png,gif,webp}",
    { eager: true }
);

const getImagePath = (jsonPath: string) => {
    const fullPath = `/src/assets${jsonPath}`;
    if (!localImages[fullPath]) return null;
    return localImages[fullPath].default;
};
---

<div class={`flex flex-col lg:flex-row gap-10 lg:gap-20 items-center lg:items-start ${isReverse ? 'lg:flex-row-reverse' : ''}`}>
    
    <div class={`w-full lg:w-2/5 ${isReverse ? 'lg:text-left' : 'lg:text-right'}`}>
        <h3 class="font-commissioner font-semibold text-3xl lg:text-4xl text-kiarita-black mb-6">
            {periodo}
        </h3>

        <div class="space-y-8">
            {eventos.map((evento) => (
                <p class="font-inter text-kiarita-gray-dark leading-relaxed text-base font-medium">
                    <span class="text-kiarita-green text-sm lg:text-base font-semibold block mb-1">
                        {evento.subtitulo}
                    </span>
                    {evento.texto}
                </p>
            ))}
        </div>
    </div>

    <div class="w-full lg:w-3/5">
        <Image
            src={getImagePath(imagen)!}
            alt={`Historia ${periodo}`}
            class="w-full h-auto max-h-[450px] object-cover object-center shadow-md rounded-sm"
        />
        <p class="text-xs font-inter text-kiarita-gray-dark font-light mt-3 italic text-center lg:text-left">
            {pie_imagen}
        </p>
    </div>
</div>